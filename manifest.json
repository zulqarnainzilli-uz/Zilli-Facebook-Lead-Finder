{
  "manifest_version": 3,
  "name": "Zilli - Facebook Lead Finder",
  "version": "1.0.0",
  "description": "Find and extract Facebook business leads with email, phone, and social links",
  "author": "Zilli Team",
  
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "webRequest",
    "activeTab"
  ],

  "host_permissions": [
    "https://www.facebook.com/*",
    "https://facebook.com/*"
  ],

  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Zilli Lead Finder"
  },

  "background": {
    "service_worker": "src/background/service-worker.js"
  },

  "content_scripts": [
    {
      "matches": ["https://www.facebook.com/*", "https://facebook.com/*"],
      "js": ["src/sidebar/sidebar.js", "src/content/content-script.js"],
      "css": ["assets/theme.css"]
    }
  ]
}
